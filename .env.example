# Copy to .env and change all values before production use.
JWT_SECRET=replace-with-long-random-secret-at-least-32-chars
POST_DB_PASSWORD=replace-me
SSO_DB_PASSWORD=replace-me
INTERNAL_API_KEY=replace-me
APP_SEED_USERS=true
SEED_ADMIN_PASSWORD=replace-with-strong-admin-password
SEED_EDITOR_PASSWORD=replace-with-strong-editor-password
MEDIA_MAX_IMAGE_BYTES=10485760
MEDIA_MAX_VIDEO_BYTES=104857600
# Comma-separated browser origins allowed to call the gateway (admin-ui, Vite, public-ui, Tilda).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:8088,http://127.0.0.1:8088,http://localhost:8089,http://127.0.0.1:8089
PUBLIC_SITE_NAME=Блог АТРИС
